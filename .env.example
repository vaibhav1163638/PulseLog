# ==================================================
# MediTalk AI — Environment Variables
# ==================================================
# Copy this to .env.local and fill in your values.

# ──────────────────────────────────────────────────
# Auth.js v5 (required)
# ──────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=9f3c1e4a8d7b2c6f5e1a0b9c4d8f7a2e6c1b3d9e5f8a2c7b4d6e1f0a3c9b7d2

# Set to your domain in production (Vercel auto-sets this)
# Locally, leave as http://localhost:3000
AUTH_URL=http://localhost:3000

# Also set these for backwards-compat with some Auth.js internals:
NEXTAUTH_SECRET=your_auth_secret_here
NEXTAUTH_URL=http://localhost:3000

# ──────────────────────────────────────────────────
# Google OAuth (required)
# ──────────────────────────────────────────────────
AUTH_GOOGLE_ID=400881978107-t3j03li19kodtu25vphepe48ubj7julg.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=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

# ──────────────────────────────────────────────────
# MongoDB (required for full functionality)
# ──────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/meditalk?retryWrites=true&w=majority
# ──────────────────────────────────────────────────
# OpenRouter (required for AI features)
# Get your key at https://openrouter.ai/keys
# ──────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=MediTalk AI

# ──────────────────────────────────────────────────
# AWS S3 (optional — PDF/audio storage)
# ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=meditalk-ai

# ──────────────────────────────────────────────────
# App~
# ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
