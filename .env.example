# ==================================================
# MediTalk AI — Environment Variables
# ==================================================
# Copy this to .env.local and fill in your values.

# ──────────────────────────────────────────────────
# Auth.js v5 (required)
# ──────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=

# Set to your domain in production (Vercel auto-sets this)
# Locally, leave as http://localhost:3000
AUTH_URL=

# Also set these for backwards-compat with some Auth.js internals:
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# ──────────────────────────────────────────────────
# Google OAuth (required)
# ─────────────────────────────────────────────
AUTH_GOOGLE_ID=400
AUTH_GOOGLE_SECRET=G
# ──────────────────────────────────────────────────
# MongoDB (required for full functionality)
# ──────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username
# ──────────────────────────────────────────────────
# OpenRouter (required for AI features)
# Get your key at https://openrouter.ai/keys
# ──────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=MediTalk AI

# ──────────────────────────────────────────────────
# AWS S3 (optional — PDF/audio storage)
# ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=meditalk-ai

# ──────────────────────────────────────────────────
# App~
# ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
